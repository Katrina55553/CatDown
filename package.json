{
  "name": "catdown",
  "version": "0.3.0",
  "description": "CatDown - Windows 桌面下班倒计时小部件",
  "main": "./out/main/index.js",
  "author": "Katrina55553",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Katrina55553/CatDown.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node scripts/test.cjs",
    "test:watch": "node scripts/test.cjs --watch"
  },
  "dependencies": {
    "cropperjs": "^1.6.2",
    "dayjs": "^1.11.13",
    "pinia": "^2.2.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.10"
  },
  "build": {
    "appId": "com.katrina.catdown",
    "productName": "CatDown",
    "copyright": "Copyright © 2026 Katrina55553",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CatDown-${version}-${arch}-setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CatDown"
    }
  }
}
